# Airtable Configuration
# Get your Personal Access Token from: https://airtable.com/create/tokens
# Scopes needed: data.records:read, data.records:write
AIRTABLE_PAT=pat_YOUR_TOKEN_HERE

# Base ID — find in Airtable URL: https://airtable.com/BASE_ID/...
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# Table name (must match exactly, case-sensitive)
AIRTABLE_TABLE_NAME=Tournament Registrations

# Server
PORT=3000
